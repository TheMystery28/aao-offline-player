{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AAO Offline Player",
  "version": "0.1.0",
  "identifier": "fr.aaonline.offline-player",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AAO Offline Player",
        "width": 1130,
        "height": 750,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../engine/player.html": "engine/player.html",
      "../engine/localstorage_bridge.html": "engine/localstorage_bridge.html",
      "../engine/bridge.js": "engine/bridge.js",
      "../engine/Javascript/": "engine/Javascript/",
      "../engine/CSS/": "engine/CSS/",
      "../engine/Languages/": "engine/Languages/",
      "../engine/img/": "engine/img/"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
